From 73bd712cd31ccdcb9c73d5aa6fef1f6ece4d6a63 Mon Sep 17 00:00:00 2001
From: Christophe Guillon <christophe.guillon@inria.fr>
Date: Sun, 2 Feb 2025 15:43:12 +0100
Subject: [PATCH 3/3] Work around comatibility for python 3.12+

In the ethosn backaend distrutils is used but
deprecated in 3.12+.
Import module lately such that tvm works when not using
ethosn backend.
---
 python/tvm/relay/op/contrib/ethosn.py | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/python/tvm/relay/op/contrib/ethosn.py b/python/tvm/relay/op/contrib/ethosn.py
index 81534d4..76558c2 100644
--- a/python/tvm/relay/op/contrib/ethosn.py
+++ b/python/tvm/relay/op/contrib/ethosn.py
@@ -17,7 +17,6 @@
 # pylint: disable=invalid-name, unused-argument
 """Arm(R) Ethos(TM)-N NPU supported operators."""
 from enum import Enum
-from distutils.version import LooseVersion
 
 import tvm.ir
 from tvm.relay import transform
@@ -116,6 +115,8 @@ def partition_for_ethosn(mod, params=None, **opts):
     -------
     ret : annotated and partitioned module.
     """
+    from distutils.version import LooseVersion
+
     api_version = ethosn_api_version()
     supported_api_versions = ["3.2.0"]
     if all(api_version != LooseVersion(exp_ver) for exp_ver in supported_api_versions):
@@ -433,6 +434,7 @@ def split(expr):
     """Check if a split is supported by Ethos-N."""
     if not ethosn_available():
         return False
+    from distutils.version import LooseVersion
     if ethosn_api_version() == LooseVersion("3.0.1"):
         return False
     if not _ethosn.split(expr):
