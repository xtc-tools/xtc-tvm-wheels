From e9aa8f9cac14f9a37766867fcb418ddb8c13d71b Mon Sep 17 00:00:00 2001
From: Christophe Guillon <christophe.guillon@inria.fr>
Date: Fri, 7 Jun 2024 12:48:43 +0200
Subject: [PATCH] Fix race on ComputationCache

The ComputationCache in the common subexpression optimization is
static and hence global to all threads/compilation contexts.
This cause race conditions when updating the underlying HashTable.

Fix by declaring the ComputationCache thread local.
---
 src/tir/transforms/common_subexpr_elim_tools.cc | 2 +-
 src/tir/transforms/common_subexpr_elim_tools.h  | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/tir/transforms/common_subexpr_elim_tools.cc b/src/tir/transforms/common_subexpr_elim_tools.cc
index ba101ce4..7fdd55e9 100644
--- a/src/tir/transforms/common_subexpr_elim_tools.cc
+++ b/src/tir/transforms/common_subexpr_elim_tools.cc
@@ -48,7 +48,7 @@ namespace tir {
 
 // cache_ is a static variable of the class ComputationsDoneBy, and C++ requires to define here
 // such static attribute, otherwise it causes a linking error.
-ComputationCache ComputationsDoneBy::cache_;
+thread_local ComputationCache ComputationsDoneBy::cache_;
 
 /* ********************************** Class ComputationsDoneBy **********************************
 *********************************************************************************************** */
diff --git a/src/tir/transforms/common_subexpr_elim_tools.h b/src/tir/transforms/common_subexpr_elim_tools.h
index 841f1d65..40f6e1fe 100644
--- a/src/tir/transforms/common_subexpr_elim_tools.h
+++ b/src/tir/transforms/common_subexpr_elim_tools.h
@@ -112,7 +112,7 @@ class ComputationsDoneBy : public StmtExprVisitor {
   // The object being constructed and "returned" by the VisitExpr()/VisitStmt() methods
   ComputationTable table_of_computations_;
   // Cache for preventing to compute repeatedly the computations done by the same stmt or expr
-  static ComputationCache cache_;
+  static thread_local ComputationCache cache_;
 };
 
 /*!
